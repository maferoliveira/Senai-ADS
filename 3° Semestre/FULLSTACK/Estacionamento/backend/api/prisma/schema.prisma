generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Automovel{
  id Int @id @default(autoincrement())
  placa String
  proprietario String
  tipo TIPO
  modelo String
  telefone String
  marca String
  cor String
  ano Int?
} 
enum TIPO{
  carro
  moto
  van
  onibus
  caminhao
}
model Estadia{
  id Int @id @default(autoincrement())
  placa String
  entrada DateTime
  saida DateTime?
  valorHora Float
  valorTotal Float?
}