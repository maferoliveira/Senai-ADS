generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model carros {
  id     Int    @id @default(autoincrement())
  marca  String
  modelo String
  ano    String
  placa  String
}

model clientes {
  id       Int    @id @default(autoincrement())
  nome     String
  cpf      String
  email    String
  cnh      String
}
